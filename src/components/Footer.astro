---
const year = new Date().getFullYear();
---

<footer id="reserve">
  <!-- Conversion CTA on every page -->
  <div class="foot-cta">
    <span class="eyebrow">Reservations</span>
    <h2>Join us at the table</h2>
    <p>Open Wednesday – Sunday · Seatings from 5pm · Limited tables nightly.</p>
    <a class="btn btn-solid lg" href="tel:+15550142">Book your table</a>
  </div>

  <div class="foot-cols">
    <div class="foot-col">
      <h3>Visit</h3>
      <p>14 Orchard Lane<br />Portland, OR 97204</p>
      <a href="tel:+15550142">+1 (555) 0142</a>
      <a href="mailto:hello@verdant.restaurant">hello@verdant.restaurant</a>
    </div>

    <div class="foot-col">
      <h3>Hours</h3>
      <p>Wed – Fri · 5pm – 11pm</p>
      <p>Sat – Sun · 4pm – 11pm</p>
      <p>Mon – Tue · Closed</p>
    </div>

    <div class="foot-col">
      <h3>Explore</h3>
      <a href="/menu">Menu</a>
      <a href="/#philosophy">Our Story</a>
      <a href="/contact">Contact</a>
    </div>

    <div class="foot-col">
      <h3>Follow</h3>
      <div class="socials">
        <a href="https://instagram.com" aria-label="Instagram" target="_blank" rel="noopener">
          <svg viewBox="0 0 24 24" aria-hidden="true" focusable="false" fill="none" stroke="currentColor" stroke-width="1.6">
            <rect x="3" y="3" width="18" height="18" rx="5"></rect>
            <circle cx="12" cy="12" r="4"></circle>
            <circle cx="17.2" cy="6.8" r="1" fill="currentColor" stroke="none"></circle>
          </svg>
        </a>
        <a href="https://facebook.com" aria-label="Facebook" target="_blank" rel="noopener">
          <svg viewBox="0 0 24 24" aria-hidden="true" focusable="false" fill="currentColor">
            <path d="M13.5 21v-7h2.3l.4-2.8h-2.7V9.4c0-.8.2-1.3 1.4-1.3h1.4V5.6c-.3 0-1.2-.1-2.2-.1-2.2 0-3.7 1.3-3.7 3.8v2.1H8v2.8h2.3V21h3.2z"></path>
          </svg>
        </a>
        <a href="https://x.com" aria-label="X" target="_blank" rel="noopener">
          <svg viewBox="0 0 24 24" aria-hidden="true" focusable="false" fill="currentColor">
            <path d="M17.5 3h3l-6.6 7.5L21.7 21h-5.9l-4.2-5.5L6.7 21H3.6l7-8L2.7 3h6l3.8 5z"></path>
          </svg>
        </a>
        <a href="https://tiktok.com" aria-label="TikTok" target="_blank" rel="noopener">
          <svg viewBox="0 0 24 24" aria-hidden="true" focusable="false" fill="currentColor">
            <path d="M16.5 3c.3 2 1.5 3.4 3.5 3.6V9c-1.3 0-2.5-.4-3.5-1v6.2c0 3-2.2 5.3-5.1 5.3A5 5 0 0 1 6.3 14c.3-2.4 2.3-4.2 4.7-4.1v2.6c-.3-.1-.6-.1-.9-.1-1.2 0-2.2 1-2.2 2.2 0 1.3 1 2.3 2.2 2.3 1.3 0 2.3-1 2.3-2.4V3h2.1z"></path>
          </svg>
        </a>
      </div>
    </div>
  </div>

  <div class="foot-bottom">© {year} Verdant · Farm-to-table dining · Portland, OR</div>
</footer>
