---
// Self-hosted fonts (bundled & served same-origin — no render-blocking
// request to fonts.googleapis.com). Only the weights actually used.
import "@fontsource/cormorant-garamond/400.css";
import "@fontsource/cormorant-garamond/400-italic.css";
import "@fontsource/cormorant-garamond/500.css";
import "@fontsource/cormorant-garamond/600.css";
import "@fontsource/jost/300.css";
import "@fontsource/jost/400.css";
import "@fontsource/jost/500.css";

import "../styles/global.css";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";

const {
  title = "Verdant — Farm-to-Table Restaurant",
  description = "Verdant is a farm-to-table restaurant rooted in fire, earth and season. Wood-fired plates, foraged greens and a quiet kind of luxury. Reserve your table.",
  image = "https://images.unsplash.com/photo-1414235077428-338989a2e8c0?auto=format&fit=crop&w=1200&q=80",
  preloadImage = null, // LCP image to fetch with high priority (e.g. hero)
} = Astro.props;

const SITE = "https://verdant.restaurant";
const canonical = SITE + Astro.url.pathname;

const schema = {
  "@context": "https://schema.org",
  "@type": "Restaurant",
  name: "Verdant",
  description,
  image,
  url: SITE,
  servesCuisine: "Farm-to-table",
  priceRange: "$$$",
  telephone: "+1-555-0142",
  acceptsReservations: "True",
  menu: SITE + "/menu",
  address: {
    "@type": "PostalAddress",
    streetAddress: "14 Orchard Lane",
    addressLocality: "Portland",
    addressRegion: "OR",
    postalCode: "97204",
    addressCountry: "US",
  },
  openingHoursSpecification: [
    {
      "@type": "OpeningHoursSpecification",
      dayOfWeek: ["Wednesday", "Thursday", "Friday", "Saturday", "Sunday"],
      opens: "17:00",
      closes: "23:00",
    },
  ],
  aggregateRating: {
    "@type": "AggregateRating",
    ratingValue: "4.9",
    reviewCount: "2143",
  },
};
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="canonical" href={canonical} />
    <meta name="generator" content={Astro.generator} />

    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="robots" content="index, follow" />
    <meta name="theme-color" content="#15120e" />

    <!-- Open Graph / Facebook (SMO) -->
    <meta property="og:type" content="restaurant.restaurant" />
    <meta property="og:site_name" content="Verdant" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={image} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="800" />
    <meta property="og:image:alt" content="Verdant restaurant" />
    <meta property="og:url" content={canonical} />
    <meta property="og:locale" content="en_US" />

    <!-- Twitter / X (SMO) -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={image} />

    {
      preloadImage && (
        <link rel="preload" as="image" href={preloadImage} fetchpriority="high" />
      )
    }

    <script type="application/ld+json" set:html={JSON.stringify(schema)} />
  </head>
  <body>
    <a class="skip-link" href="#main">Skip to content</a>
    <Header />
    <main id="main">
      <slot />
    </main>
    <Footer />

    <script>
      // Tiny, cheap scroll-reveal. Marks <html> as JS-capable so the
      // reveal hidden state only applies when this can run (no-JS = visible).
      document.documentElement.classList.add("js");
      const revealEls = document.querySelectorAll(".reveal");
      if (revealEls.length) {
        if (!("IntersectionObserver" in window)) {
          revealEls.forEach((el) => el.classList.add("in"));
        } else {
          const io = new IntersectionObserver(
            (entries) => {
              for (const e of entries) {
                if (e.isIntersecting) {
                  e.target.classList.add("in");
                  io.unobserve(e.target);
                }
              }
            },
            { threshold: 0.15, rootMargin: "0px 0px -8% 0px" }
          );
          revealEls.forEach((el) => io.observe(el));
        }
      }
    </script>
  </body>
</html>
